# Entorno y Servidor
NODE_ENV="development"
PORT=3000

# Modo de Ejecución (Shadow Trading / Dry-Run vs Producción Real)
DRY_RUN="true"                 # true = Shadow Trading (sin dinero real); false = Producción en vivo

# Parámetros del Grid Adaptativo (ATR)
GRID_SYMBOL="BTC/USDT"
GRID_LEVELS="15"
GRID_INVESTMENT="1000.00"
ATR_PERIOD="14"                # Período clásico para evaluar volatilidad
ATR_TIMEFRAME="1h"             # Velas de 1 hora para calcular la expansión/compresión
MIN_GRID_RANGE_USD="1500.00"   # Techo mínimo de compresión en baja volatilidad
MAX_GRID_RANGE_USD="6000.00"   # Tope máximo de expansión en alta volatilidad

# Parámetros de Gestión de Riesgo
MAX_ORDER_VALUE_USD="150.00"
MAX_OPEN_ORDERS="20"

# Base de Datos PostgreSQL (Prisma ORM)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grid_bot?schema=public"

# Credenciales de API Exchange (Binance Testnet / Sandbox para pruebas en vivo)
EXCHANGE_ID="binance"
EXCHANGE_API_KEY="mock_api_key"
EXCHANGE_API_SECRET="mock_api_secret"
EXCHANGE_TESTNET="true"
