DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grid_bot?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=grid_bot

# Configuración del Exchange (Testnet por defecto)
EXCHANGE_ID="binance"
EXCHANGE_API_KEY=""
EXCHANGE_SECRET=""
EXCHANGE_TESTNET=true

# Configuración Dinámica de la Grilla de Trading (15 niveles cada $200 USD)
GRID_SYMBOL="BTC/USDT"
GRID_LOWER_PRICE="63000.00"
GRID_UPPER_PRICE="66000.00"
GRID_LEVELS="15"
GRID_INVESTMENT="1000.00"

# Parámetros de Gestión de Riesgo (Protección real)
MAX_ORDER_VALUE_USD="150.00"
MAX_OPEN_ORDERS="20"
