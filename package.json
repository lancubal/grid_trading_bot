{
  "name": "day-trading-bot",
  "version": "1.0.0",
  "description": "Grid Trading Bot for BTC using CCXT, Prisma, PostgreSQL and Zod",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "backtest": "tsx src/backtest/run.ts",
    "backtest:batch": "tsx src/backtest/batch.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "keywords": [
    "trading",
    "bot",
    "grid-trading",
    "crypto",
    "ccxt"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ccxt": "^4.4.0",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
